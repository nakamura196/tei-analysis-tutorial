  "persons": {
    "nakahira": [
      "安井仲平",
      "号は息軒。日向国清武村の生まれ。痘痕があり片目で背が低い。大坂で篠崎小竹、江戸で古賀侗庵に学び昌平黌に入る。飫肥藩の侍読・助教を経て江戸で三計塾を開き、大儒として知られた。本作の「猿」と渾名された主人公。安井息軒(1799-1876)"
    ],
    "sayo": [
      "お佐代さん",
      "川添家の妹娘。「岡の小町」と呼ばれた美貌の娘だが、自ら望んで不男の仲平に嫁ぐ。粗服で夫に仕え、五十一歳の正月四日に没する。本作の表題「安井夫人」"
    ],
    "soshu": [
      "安井滄洲",
      "仲平の父。飫肥藩の儒者で藩の教授・振徳堂総裁。文中では「滄洲翁」。六十九歳のとき中風で没する"
    ],
    "bunji": [
      "文治",
      "仲平の兄。背が高く色白の美男で、渾名は「猿引き」。二十六歳で病没する"
    ],
    "toyo": [
      "お豊さん",
      "川添家の姉娘。器量は十人並みだが快活で率直。滄洲翁が仲平のよめにと望むが「ご亭主にするのはいやでございます」と拒絶する。お佐代の姉"
    ],
    "yae": [
      "八重",
      "滄洲翁が候補に思い浮かべた親戚の娘。定府勤めの父が江戸の女に生ませ、江戸風の化粧と江戸詞を身につけている"
    ],
    "nagakura": [
      "長倉のご新造",
      "仲平の姉。長倉家に嫁している。滄洲翁の意を受けて川添家へ縁談の使者に立つ。婚礼では夫婦で媒妁を務める"
    ],
    "kawazoe": [
      "川添のご新造",
      "お豊・お佐代の母。川添家の女主人。仲平贔屓で、お佐代の申し出を長倉のご新造に取り次ぐ"
    ],
    "otokichi": [
      "音吉",
      "川添家に使われている下男。長倉のご新造を呼び戻しに走る"
    ],
    "shinozaki": [
