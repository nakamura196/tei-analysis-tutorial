  "persons": {
    "shiraito": [
      "滝の白糸",
      "水芸の太夫。本名は水島友(みずしまとも)。越後新潟の生まれ。馭者の村越欣弥に惚れ込み、東京遊学の学資を仕送りする。強盗に金を奪われ、金策のため六勝亭の夫婦を殺害して死刑を宣告される。「白糸」「水島友」「村越友」「お友」とも(底本の誤植『自糸』1件も同一人物として同じ id に束ねた)"
    ],
    "kinya": [
      "村越欣弥",
      "高岡片原町の生まれ。金沢の士族。乗り合い馬車の馭者から、白糸の仕送りで東京に遊学し、金沢地方裁判所の検事代理となる。白糸を殺人犯として起訴し、宣告の夕べに自殺する。「金さん」「欣さん」「欣様」「金公」とも"
    ],
    "kirita": [
      "桐田",
      "兼六園内の席貸し「六勝亭」の主翁。金満家の隠居。夫婦ともに白糸に殺害される"
    ],
    "chomatsu": [
      "長松",
      "猿芝居の猿の名。年増の女に連れられ金沢から福井へ発つ(名を持つ動物)"
    ],
    "kichiko": [
      "吉公",
      "高岡石動間の乗り合い馬車の客引きの小僧。馭者(欣弥)から「吉公」と呼ばれる"
    ],
    "chiyoko": [
      "千代公",
      "長松と同じ猿芝居の一座の連れの呼び名(金沢は二度目という)。長松(猿)のもう一匹の相方とも一座の人とも取れるが、本文からは断定できない"
    ],
    "shin": [
      "新",
      "白糸の一座の囃子方の男。天神橋で眠る欣弥を、白糸が一度「新」と見誤る"
    ]
  },
