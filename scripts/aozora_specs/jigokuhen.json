    "yoshihide": [
      "良秀",
      "本朝第一と称された画師。堀川の大殿様の命で地獄変の屏風を描く。立居振舞が猿のようだとして「猿秀」の諢名でも呼ばれた"
    ],
    "saru-yoshihide": [
      "猿の良秀",
      "丹波の国から献上された小猿。若殿様が画師をからかって「良秀」と名づけた。良秀の娘になつき、最後は娘とともに焔の中に果てる"
    ],
    "kawanari": [
      "川成",
      "百済河成(782–853)。平安初期の画家。昔の名匠の例として言及される"
    ],
    "kanaoka": [
      "金岡",
      "巨勢金岡。平安前期の宮廷画家。昔の名匠の例として言及される"
    ],
    "minamoto-no-toru": [
      "融",
      "融の左大臣=源融(822–895)。河原院の主。その霊が夜ごと現れたという噂として言及される"
    ],
    "kada": [
      "華陀",
      "華佗。後漢末の伝説的名医。その術を伝えた震旦の僧への言及に現れる"
    ],
    "chiraeiju": [
      "智羅永寿",
      "昔、震旦から渡ってきたと伝えられる天狗の名(今昔物語集などに見える)。弟子が良秀につけた諢名として引かれる"
    ],
    "daiitoku-myoo": [
      "大威徳明王",
      "五大明王の一。大殿様誕生の際に御母君の夢枕に立ったと伝えられる"
    ],
    "fudo-myoo": [
      "不動明王",
      "五大明王の中心。良秀が無頼の放免の姿を写して描いたという逸話に現れる"
    ],
    "monju": [
      "文殊",
      "文殊菩薩。良秀が大殿様の寵愛の童の顔を写して稚児文殊を描いたという逸話に現れる"
    ]
  },
