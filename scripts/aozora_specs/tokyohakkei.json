  "title": "東京八景",
  "author": "太宰治",
  "fixes": {},
  "persons": {
    "h": [
      "Ｈ",
      "「私」が昭和五年から六年間ともに暮した女性。芸妓出身で、作中では頭文字のみで示される(モデルは小山初代とされる)。全59回の言及がすべて同一人物"
    ],
    "s": [
      "Ｓ",
      "小石川に住む「私」の大先輩の作家。作中表記は「Ｓさん」。破門同然だった「私」を上野・銀座に伴い、その姿が東京八景の一景となる(モデルは佐藤春夫とされる)"
    ],
    "t": [
      "Ｔ",
      "「私」の妻の妹の許嫁。応召し増上寺山門前から戦地へ出発する青年。作中表記は主に「Ｔ君」"
    ],
    "ochiai-kazuo": [
      "落合一雄",
      "「私」が日本橋・八丁堀に潜伏した際に名乗った変名(「北海道生まれ」という触れ込み)"
    ],
    "shurindo": [
      "朱麟堂",
      "「私」が淀橋・柏木に住んだ頃、俳句に凝って用いた号"
    ],
    "tatsuno-yutaka": [
      "辰野隆",
      "フランス文学者(1888–1964)。東京帝大の教授。作中表記は「辰野隆先生」"
    ],
    "rousseau": [
      "ルソオ",
      "ジャン＝ジャック・ルソー(1712–1778)。『懺悔録』の著者として言及。作中表記は「ルソオ」"
    ],
    "akutagawa-ryunosuke": [
      "芥川龍之介",
      "小説家(1892–1927)。Ｓさん宅での談話の話題として言及"
    ],
