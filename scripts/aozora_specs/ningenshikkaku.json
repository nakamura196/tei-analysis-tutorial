    "oba-yozo": [
      "大庭葉蔵",
      "手記の書き手である主人公。作中表記は「葉蔵」「大庭」、愛称「葉ちゃん」。「上司幾太」は漫画発表時のふざけた匿名（ペンネーム）"
    ],
    "horiki-masao": [
      "堀木正雄",
      "画学生くずれの遊び友達。東京の下町生れで主人公より六つ年長。作中表記は主に「堀木」"
    ],
    "shibuta": [
      "渋田",
      "書画骨董商（青竜園）。父の別荘に出入りしていた同郷人で、主人公の身元引受人。あだ名は「ヒラメ」だが、表層形「ヒラメ」は魚の意の用例と衝突するため未タグ（検証レポート参照）"
    ],
    "tsuneko": [
      "ツネ子",
      "銀座の大カフエの女給。広島出身。主人公と鎌倉で入水し、ひとりだけ死んだ"
    ],
    "shizuko": [
      "シヅ子",
      "雑誌社に勤める女記者。甲州生れの二十八歳。高円寺のアパートで主人公と同棲。堀木は「高円寺女史」とも呼ぶ"
    ],
    "shigeko": [
      "シゲ子",
      "シヅ子の五つになる女児。作中表記は「シゲ子」「シゲちゃん」"
    ],
    "yoshiko": [
      "ヨシ子",
      "京橋のスタンド・バア向かいの煙草屋の娘。主人公の内縁の妻。作中表記は「ヨシ子」「ヨシちゃん」"
    ],
    "takeichi": [
      "竹一",
      "中学の同級生。主人公のワザとの失敗を見破り、二つの予言を残した"
    ],
