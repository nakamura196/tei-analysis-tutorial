  "persons": {
    "genzaburo": [
      "恩地源三郎",
      "能楽師。当流第一の老手で喜多八の叔父(伯父)。六十二三歳。伊勢参宮の道中を『膝栗毛』になぞらえ、自ら「弥次郎兵衛」と称する"
    ],
    "kitahachi": [
      "恩地喜多八",
      "源三郎の甥(養子)。能楽界の逸材だったが、按摩の宗山を辱め屈死させたため勘当され、門附(かどづけ)に身を落とす。作中の語り手の一人"
    ],
    "sesso": [
      "辺見雪叟",
      "本名 辺見秀之進。七十八歳の小鼓の名人で、孫に代を譲って隠居。源三郎の道連れ。作中では戯れに「捻平」と呼ばれる"
    ],
    "soyama": [
      "宗山",
      "伊勢山田・古市の按摩鍼。本名 惣市。謡の名人を自任する高慢な盲人で、喜多八に芸で辱められ、その夜のうちに屈死する"
    ],
    "omie": [
      "お三重",
      "桑名・島屋の新妓。伊勢の生まれで宗山の遺児。鳥羽の廓を経て桑名へ売られ、門附の喜多八に舞を仕込まれる"
    ],
    "osen": [
      "お千",
      "湊屋の座敷に出る芸妓。三味線を弾き、お三重をかばう年増の姉さん"
    ],
    "kino": [
      "喜野",
      "湊屋の小女(こおんな)。座敷の使い走りをする"
    ],
    "osode": [
      "お袖",
      "宗山の娘。喜多八が宗山の家で見かけた島田髷の娘。宗山は「袖や」と呼ぶ(お三重との同一性は本文中で明示されない)"
    ],
    "otohime": [
      "乙姫",
      "竜宮の乙姫。伝説上の存在としての言及"
    ],
    "kannon": [
      "観音薩埵",
      "観世音菩薩。謡曲『海人』の詞章「南無や志渡寺の観音薩埵」中の言及"
    ],
    "tadamichi": [
      "法性寺入道前の関白太政大臣",
      "藤原忠通(1097-1164)。小倉百人一首の歌人名義。車夫の長口上のなかで実在人物への言及として現れる"
    ]
  },
