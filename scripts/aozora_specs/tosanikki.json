    ],
    "masatsura": [
      "昌連",
      "正月四日に酒と佳肴を贈った人物。伝未詳"
    ],
    "fumitoki": [
      "文時",
      "正月十二日条に見える同行者。維茂とともに船が遅れた。伝未詳"
    ],
    "koremochi": [
      "維茂",
      "正月十二日条に見える同行者。文時とともに船が遅れた。伝未詳"
    ],
    "yukimasa": [
      "長谷部の行政",
      "長谷部行政。国境まで一行を見送った人物。伝未詳"
    ],
    "narihira": [
      "業平",
      "在原業平(825–880)。歌人。正月八日条で月の歌「あかなくにまだきも月の…」の作者として、また渚の院の桜の歌の作者として言及される。本文では「業平の君」「在原の業平の中將」"
    ],
    "nakamaro": [
      "安倍の仲麻呂",
      "阿倍仲麻呂(698頃–770)。遣唐留学生。正月二十日条で唐土での「あをうなばら…」の歌の作者として語られる。本文の表記は「安倍の仲麻呂」「仲麻呂のぬし」"
    ],
