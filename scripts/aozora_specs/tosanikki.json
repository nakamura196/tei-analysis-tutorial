    "tokizane": [
      "藤原の言實",
      "藤原言実。土佐国の役人。門出の日に馬の餞をし、浦戸・大湊まで見送った。本文では「藤原の言實」「藤原のとき實」「藤原のときざね」と表記が揺れる"
    ],
    "yasunori": [
      "八木の康教",
      "八木康教。国司の下僚ではないが、十二月廿三日に馬の餞をした人物。伝未詳"
    ],
    "suenaka": [
      "橘の季衡",
      "橘季衡。浦戸・国境まで一行を見送った人物。伝未詳"
    ],
    "chimine": [
      "山口の千岑",
