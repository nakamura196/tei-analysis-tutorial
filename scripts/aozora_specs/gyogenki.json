  "persons": {
    "gyogenki": [
      "魚玄機",
      "唐の女詩人(844頃–868)。長安の倡家に生れ、温庭筠に詩を学ぶ。李億の側室となった後、咸宜観の女道士となり、婢の緑翹を殺して咸通九年に斬られた。本作の主人公。作中では「玄機」「魚」とも記され、字は幼微、また蕙蘭とも称した"
    ],
    "onki": [
      "温庭筠",
      "晩唐の詩人(温岐、812頃–866頃)。字は飛卿。醜怪な容貌から「温鍾馗」、八叉手で八韻を成すことから「温八叉」の諢名がある。玄機の詩の師"
    ],
    "shoki": [
      "鍾馗",
      "疫鬼を退治する伝説上の存在。その醜怪な容貌から温庭筠の諢名となった"
    ],
    "reikoto": [
      "令狐綯",
      "晩唐の宰相(795–872)。大中四年に宰相となり、大中十三年に罷めて揚州刺史となる。作中では「綯」とも記される"
    ],
    "reikokaku": [
      "令狐滈",
      "令狐綯の子。旗亭に妓を呼ぶ貴公子。作中では「令狐」とも記される"
    ],
    "hisei": [
      "斐誠",
      "令狐滈の遊び仲間の貴公子。作中では「斐」とも記される"
    ],
    "rioku": [
      "李億",
      "素封家。温庭筠の友人で、玄機を側室に迎えるが、妻の実家に責められて玄機を逐う。作中では「李」とも記される"
    ],
    "rihaku": [
      "李白",
      "盛唐の詩人(701–762)。「隴西の李白」として言及される"
    ],
    "toho": [
      "杜甫",
      "盛唐の詩人(712–770)。「襄陽の杜甫」として言及される"
    ],
    "hakukyoi": [
      "白居易",
      "中唐の詩人(772–846)。長恨歌・琵琶行の作者として言及される"
    ],
    "genbishi": [
      "元微之",
      "元稹(779–831)。白居易と名を斉しくした詩人として言及される"
    ],
    "rishoin": [
      "李商隠",
      "晩唐の詩人(813頃–858)。温庭筠と並ぶ当代の詩人として言及される"
    ],
    "danseishiki": [
      "段成式",
      "晩唐の文人(803頃–863)。『酉陽雑俎』の著者。李商隠・温庭筠と併せて三名家と称された。作中では「段」とも記される"
    ],
    "roshi": [
      "老子",
      "道家の祖とされる人物。唐の王室が李姓であることから先祖と称された。作中では「老君」とも記される"
    ],
    "soshi": [
      "荘子",
      "荘周。道家の思想家、およびその書『荘子』(=南華真経)。令狐綯が席上で問うた故事の出典として言及される"
    ],
    "senso": [
      "宣宗",
      "唐の第16代皇帝(810–859、在位846–859)。温庭筠の才を認めながらその人を鄙んだ"
    ],
    "iso": [
      "懿宗",
      "唐の第17代皇帝(833–873、在位859–873)。咸通九年、上奏を容れて玄機を斬に処した"
    ],
    "shinjun": [
      "沈詢",
      "晩唐の官人。知挙(科挙の試験官)として温庭筠を別席に隔離した"
    ],
    "chosen": [
