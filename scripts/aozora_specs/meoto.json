  "persons": {
    "chouko": [
      "蝶子",
      "主人公。上塩町の一銭天婦羅屋・種吉の娘。女中奉公・おちょぼを経て北の新地の芸者となり、柳吉と駈落ちしてヤトナ芸者として働きながら柳吉を支える"
    ],
    "ryukichi": [
      "維康柳吉",
      "蝶子の相手。梅田新道の化粧品問屋の若旦那。妻子ある身で蝶子と駈落ちして勘当され、吃りで浄瑠璃と食い道楽を好む。本文では「柳吉」「維康さん」とも呼ばれる。夜店のドテ焼を好み「ドテ焼さん」と渾名された"
    ],
    "taneyoshi": [
      "種吉",
      "蝶子の父。上塩町の路地で一銭天婦羅を商う。駕籠かき人足や祭の人足もつとめる。人が良く、娘夫婦に甘い"
    ],
    "otatsu": [
      "お辰",
      "蝶子の母、種吉の女房。借金取に「板の間をたたくな」と芝居を打つ。のち子宮癌で死ぬ"
    ],
    "shinichi": [
      "信一",
      "蝶子の弟。尋常四年から夕刊売りをし、のち京都下鴨の質屋へ年期奉公に出る"
    ],
    "okin": [
      "おきん",
      "もと北の新地の芸者。高津に一軒構えてヤトナ(臨時雇の有芸仲居)の周旋屋を営み、蝶子の相談相手となる"
    ],
    "fudeko": [
      "筆子",
