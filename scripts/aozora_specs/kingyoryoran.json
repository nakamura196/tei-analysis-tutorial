  "title": "金魚撩乱",
  "author": "岡本かの子",
  "fixes": {},
  "persons": {
    "fukuichi": [
      "復一",
      "主人公。谷窪の金魚屋の当主(幼くして両親を失い、夫婦養子の宗十郎夫婦に育てられた)。関西の水産試験所で金魚の遺伝・生殖を研究し、真佐子を髣髴させる理想の新種を作ることに生涯を賭ける"
    ],
    "masako": [
      "真佐子",
      "崖邸の一人娘。鼎造の娘。復一の幼馴染で終生の偶像。バロック・ロココに凝る「非現実的な美女」として描かれ、復一の金魚創出の動機となる"
    ],
    "sojuro": [
      "宗十郎",
      "復一の養父。金魚屋の夫婦養子で、もとは荻江節の師匠。駄金魚を作りながら復一の研究を支える"
    ],
    "otsune": [
      "お常",
      "復一の養母。宗十郎の妻。復一に世間並の結婚を勧める。本文で名が示されるのは「養母のお常」の一箇所のみ"
    ],
    "teizo": [
      "鼎造",
      "真佐子の父。崖邸の主人で実業家。復一に学資を出し、のちに金魚の飼育・輸出事業へ全資力を注ぐ。鯉鰻養殖の失敗と金融恐慌で窮迫し、作中で死去する"
    ],
    "hidee": [
      "秀江",
      "関西の湖畔、出崎の魚漁家の娘。復一の「肉体の馴染み」。復一が東京へ戻ったのち関係は絶える"
    ],
    "tomoda": [
      "友田",
      "鼎造から好意を受け崖邸に出入りする三人の青年の一人。真佐子の結婚相手の候補と目された"
    ],
    "hariya": [
      "針谷",
      "鼎造から好意を受け崖邸に出入りする三人の青年の一人"
    ],
    "yokochi": [
      "横地",
      "鼎造から好意を受け崖邸に出入りする三人の青年の一人"
    ],
    "akiyama": [
      "秋山",
      "都下砂村の金魚飼育商。蘭鋳と琉金の交媒によって頭尾ともに完美な新種を得ようとし、名魚「秋錦」を生んだと語られる実在の飼育家への言及"
    ],
    "g-shi": [
      "Ｇ氏",
      "作中で伏字にされた愛魚家。理想の新種「赫耶姫」を創ろうとして家産を破り、白痴のようになって行方知れずとなる。復一の運命の先例。本文の「Ｇ氏」「Ｇさん」を @ref で統合"
    ],
    "kaguyahime": [
      "赫耶姫",
      "Ｇ氏が創り出すはずの理想の金魚に付けようとした名。竹取物語のかぐや姫に由来する命名"
    ],
    "fujimura": [
      "藤村女史",
      "真佐子の友人の女詩人。真佐子とバロック・ロココの服飾や室内装飾を語り合う。本文では一貫して「藤村女史」"
    ],
    "hidari-jingoro": [
      "左甚五郎",
      "江戸初期の伝説的な彫刻家。日光東照宮の眠り猫の作者として言及される"
    ],
    "basho": [
