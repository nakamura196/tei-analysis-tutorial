  "title": "藤十郎の恋",
  "author": "菊池寛",
  "fixes": {},
  "persons": {
    "tojuro": [
      "坂田藤十郎",
      "主人公。上方歌舞伎の名優で「三ヶ津の総芸頭」と讃えられたやつし・傾城買の名人。芸の行き詰まりを破るため、茶屋の女房お梶に偽りの恋を仕掛ける。呼びかけは「藤様」「坂田様」とも"
    ],
    "shichisaburo": [
      "中村七三郎",
      "江戸歌舞伎の名優。通称「少長」。顔見世で上京し、『傾城浅間ヶ嶽』の巴之丞で都の人気を博して藤十郎の好敵手となる"
    ],
    "hanzaemon": [
      "山下半左衛門",
      "京の芝居の座元。半左衛門座(山下座)を興行し、中村七三郎を迎える"
    ],
    "chikamatsu": [
      "近松門左衛門",
      "浪華に住む狂言作者。藤十郎の求めに応じて密夫物『大経師昔暦』を書き下ろす。作中では「近松門左」「門左衛門」とも呼ばれる"
    ],
    "danjuro": [
      "市川団十郎",
      "江戸の名優。俳号「才牛」。荒事の創始者として都に上り、藤十郎はその芸を軽んじた"
    ],
    "senju": [
      "切波千寿",
      "万太夫座の若女形。『大経師昔暦』でおさんを勤める"
    ],
    "okaji": [
      "お梶",
      "茶屋宗清の女房。宮川町の歌妓として嬌名を謳われた。藤十郎の偽りの恋を受け、のち万太夫座の楽屋で縊死する"
    ],
    "soyama-seibei": [
      "宗山清兵衛",
      "茶屋宗清の主人。お梶の夫"
    ],
    "sennojo": [
      "玉村千之丞",
      "河内通いの狂言を百五十日打ち続けたと語り伝えられる役者"
    ],
    "kyoemon": [
      "山下京右衛門",
      "藤十郎の腹心の弟子"
    ],
    "izaemon": [
      "伊左衛門",
      "藤十郎の当り役。傾城買狂言『夕霧伊左衛門』の主人公(藤屋伊左衛門)"
    ],
    "yugiri": [
      "夕霧",
      "『夕霧伊左衛門』の遊女夕霧。藤十郎の当り狂言の女主人公"
    ],
    "tomonojo": [
