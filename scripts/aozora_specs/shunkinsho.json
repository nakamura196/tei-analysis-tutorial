  "fixes": {},
  "persons": {
    "shunkin": [
      "春琴",
      "鵙屋琴（1829-1886）。大阪道修町の薬種商鵙屋の次女。九歳で失明し、生田流の箏曲・三絃の名手となる。号は春琴。本文では「春琴」「春琴女」「琴女」「鵙屋琴」と表記が揺れる"
    ],
    "sasuke": [
      "佐助",
      "温井佐助（1825-1907）。江州日野の薬屋の子。十三歳で鵙屋に丁稚奉公し春琴の手曳きとなる。のち春琴に師事、春琴の被災後に自ら両眼を突いて失明。号は琴台、のちに検校。本文では「佐助」「温井佐助」「温井検校」「琴台」「温井琴台」"
    ],
    "harumatsu": [
      "春松検校",
      "春琴および佐助の師。靱に住む生田流の検校。春琴に「春琴」の名を与えた。本文では「春松検校」「春松」"
    ],
    "anzaemon": [
      "鵙屋安左衛門",
      "春琴の父。道修町の薬種商鵙屋七代目当主。当主が代々称する名でもある。本文では「安左衛門」"
    ],
    "shige": [
      "しげ",
      "春琴の母。京都麩屋町の跡部氏の出。本文では「しげ女」"
    ],
    "teru": [
      "鴫沢てる",
      "生田流の勾当。明治七年、十二歳で春琴の家に内弟子として住み込み、晩年の春琴と佐助に仕えた語り手の証言者。本文では「鴫沢てる」「鴫沢てる女」「鴫沢勾当」「てる女」「照女」"
    ],
    "ritaro": [
      "利太郎",
      "土佐堀の雑穀商美濃屋九兵衛の忰。春琴の門弟のぼんち。春琴に横恋慕し撥で眉間を割られる。春琴襲撃の加害者と目される一人"
    ],
    "kyubei": [
      "美濃屋九兵衛",
      "土佐堀の雑穀商。利太郎の父。天下茶屋の隠居所で梅見の宴を催す。本文では「九兵衛」"
    ],
    "tenko": [
