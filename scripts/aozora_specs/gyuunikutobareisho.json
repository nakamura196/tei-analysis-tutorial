  "title": "牛肉と馬鈴薯",
  "author": "国木田独歩",
  "fixes": {},
  "persons": {
    "okamoto": [
      "岡本誠夫",
      "主人公。名刺に肩書きのない文筆家。「喫驚したい」という「不思議なる願」を語る。作中表記は「岡本誠夫」「岡本」"
    ],
    "takeuchi": [
      "竹内",
      "明治倶楽部の会合の主人格。岡本の「極く旧い朋友」"
    ],
    "kamimura": [
      "上村",
      "北海道炭鉱会社の社員。同志社出身で、かつては熱心な「馬鈴薯党」だったが北海道開墾に破れて「牛肉党」に転じたと語る"
    ],
    "watanuki": [
      "綿貫",
      "背の低い、真黒の頬髭を生した紳士。「権利義務」で一貫したと自称する"
    ],
    "iyama": [
      "井山",
      "眼のしょぼしょぼした頭髪の薄い、痩方の紳士"
    ],
    "matsuki": [
      "松木",
      "真紅な顔をした、坐中で一番年の若い紳士"
    ],
    "kondo": [
      "近藤",
      "背の高い一癖ある顔構えの男。「僕は馬鈴薯党でも牛肉党でもない、嗜きで牛肉を喰うのだ」と論じる"
    ],
    "kajiwara": [
      "梶原信太郎",
      "上村と共に北海道の開墾事業に取りかかった友人。二月ほどで見切りをつけ、現在は上村と同じ会社に勤める。作中表記は「梶原信太郎」「梶原」"
    ],
    "oei": [
