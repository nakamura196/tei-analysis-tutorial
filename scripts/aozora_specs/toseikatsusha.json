  "title": "党生活者",
  "author": "小林多喜二",
  "fixes": {},
  "persons": {
    "suyama": [
      "須山",
      "語り手と同じ工場細胞の同志。倉田工業第二工場の職工。合法的な存在を保ちながら活動し、最後にビラを撒いて検挙される"
    ],
    "ito": [
      "伊藤ヨシ",
      "女の同志。臨時工として倉田工業に入り、パラシュート職場で「しるこや組」を組織する。「伊藤」「ヨシ」「ヨシ公」「ヨシちゃん」とも呼ばれる"
    ],
    "kasahara": [
      "笠原",
      "語り手と一緒に暮らす女性。会社勤めののち喫茶店で働き、語り手の非合法生活を支える"
    ],
    "ota": [
      "太田",
      "同志。倉田工業で働くが検挙され、警察で語り手のことを供述する"
    ],
    "kiyokawa": [
      "清川",
      "大衆党系の御用組合「僚友会」の幹部。慰問金募集を主張し、須山・伊藤と論争する"
    ],
    "atsuta": [
      "熱田",
      "「僚友会」の幹部。清川と行動を共にする"
    ],
    "tsuji": [
      "辻",
      "伊藤のグループの女工。しるこ屋で「サクラ」役をつとめる"
    ],
    "sasaki": [
      "佐々木",
      "伊藤のグループの女工。辻とともに「サクラ」役をつとめる"
    ],
    "yoshimura": [
      "吉村",
      "「マスク」職場の本工。キヌちゃんにラヴ・レターを出す"
    ],
    "kinu": [
      "キヌ",
      "パラシュート職場の女工(キヌちゃん)"
    ],
    "shige": [
      "シゲ",
      "女工(シゲちゃん)。仲間うちで「少し利口」と評される"
    ],
    "kimi": [
      "キミ",
      "女工(キミちゃん)。伊藤になついている"
    ],
    "kanda-hakuzan": [
      "神田伯山",
      "講談師・二代目神田伯山(1872-1932)。須山が切抜帳の話題として持ち出す"
    ],
    "kataoka-teppei": [
      "片岡鉄兵",
      "作家(1894-1944)。「日本文学全集」の巻頭写真として言及される"
    ],
    "hayama-yoshiki": [
      "葉山嘉樹",
      "プロレタリア作家(1894-1945)。「日本文学全集」の巻頭写真として言及される"
    ],
    "kataoka-chiezo": [
      "片岡千恵蔵",
      "映画俳優(1903-1983)。女工たちが見に行きたがる映画スターとして言及される"
    ],
    "lenin": [
      "レーニン",
      "ウラジーミル・レーニン(1870-1924)。戦争と労働組合をめぐる言説の典拠として引かれる"
    ],
    "shavarov": [
      "シャヴァロフ",
      "須山の切抜帳に出てくる革命家。検挙後七カ月間黙秘を貫いた人物として語られる"
    ],
    "hige": [
      "ヒゲ",
      "「ヒゲ」と呼ばれる同志。語り手たちの「一番上のポスト」にいる重要なキャップ。検挙され各署をたらい回しにされる"
    ],
    "ueda": [
      "上田",
      "同志。ヒゲとの連絡が切れたことを須山が語り手に伝える場面に登場"
    ],
    "watamasa": [
      "渡政",
      "「渡政」と呼ばれる同志。潜行したときの母親の言葉を語り手が回想する"
    ],
    "yasuji": [
      "安治",
      "語り手「私」の名。母は「安治」と呼び、運動の仲間内では「佐々木」と呼ばれる(女工の佐々木と表記が衝突するため、後者は skip で抑止し本文にはタグ付けしない)"
    ],
    "fuuten-no-goro": [
      "フウテンのゴロ",
      "「フウテンのゴロ」と呼ばれる不良。脅迫罪で検挙され、檻房で太田と一緒になりレポを託される"
    ]
  },
