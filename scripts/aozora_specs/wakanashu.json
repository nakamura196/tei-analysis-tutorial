    "sahohime": [
      "さほひめ",
      "佐保姫。春を司る女神。「合唱 一　暗香」で姉が呼びかける"
    ],
    "jingoro": [
      "甚五郎",
      "左甚五郎。伝説的な名工。松島瑞巌寺の葡萄・栗鼠の浮彫の作者と伝えられ、作中では「飛騨の名匠」とも呼ばれる。巻末の詩の結句に現れる"
    ]
  },
