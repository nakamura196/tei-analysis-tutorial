    ],
    "okinu": [
      "おきぬ",
      "「六人の処女」第二篇の主人公。前世は猛鷲であったと歌い、処女の身と鳥の魂との間に引き裂かれる女性"
    ],
    "osayo": [
      "おさよ",
      "「六人の処女」第三篇の主人公。荒磯に生まれ、狂おしい思いを笛の音に託す女性"
    ],
    "okume": [
      "おくめ",
