  "persons": {
    "odasaku": ["オダサク", "語り手「私」。大阪の風俗作家。海老原から「オダサク好みだね」と呼ばれる箇所で、作者織田作之助自身の愛称として本文に現れる"],
    "narabashi-renkichi": ["楢橋廉吉", "大阪府南河内郡林田村林田国民学校の老訓導(五十四歳)。防空頭巾姿で「私」を訪ね、現下の世相を語りながら闇煙草を売りに来る"],
    "ebihara": ["海老原", "左翼くずれの同盟記者。大阪の同人雑誌にも関係する文学青年で、白い背広に蝶ネクタイ。酒場「ダイス」のマダムをねらっており、「私」の思想の不在を高飛車に衝く"],
    "yokobori": ["横堀千吉", "「私」の小学校の同級生。散髪職人。保証人になった「私」を裏切って店の金を持ち逃げし、のち中支から復員して浮浪者となり、師走の夜に「私」を訪ねて来る。作中「横堀」とも"],
    "shizuko": ["照井静子", "カフェ美人座の女給。「私」が二十四歳のとき胸を焦がした女。神戸のダンサー、京都宮川町のダンス芸者などを経ており、のち拳闘選手と満州へ走る。作中「静子」とも"],
    "abe-sada": ["阿部定", "阿部定事件(1936年)の当事者。尾久町の待合「まさき」で情夫石田吉蔵を殺害した「稀代の妖婦」。「私」はその公判記録を探し求める。作中「お定」とも"],
    "ishida": ["石田吉蔵", "阿部定事件の被害者。料亭の経営者で、住込仲居となった定と情痴の限りを尽した末に殺される。作中「石田」とも"],
    "omiya": ["大宮", "中京商業の校長。名古屋の料亭「寿」で定と知り合い、更生させようとして援助した。公判記録中に検事への陳述が引かれる。本文では「大宮校長」"],
    "saikaku": ["西鶴", "井原西鶴(1642–1693)。『好色一代女』『世間胸算用』の作者として言及され、「私」が構想の下敷き・向うを張る相手として意識する"],
    "murakami-namiroku": ["村上浪六", "村上浪六(1865–1944)。小説家。老訓導の古い文芸談に名が出る"],
    "kikuchi-yuho": ["菊池幽芳", "菊池幽芳(1870–1947)。小説家。老訓導の古い文芸談に名が出る"],
    "george-raft": ["ジョージ・ラフト", "George Raft(1895–1980)。アメリカの映画俳優。「ダイス」のマダムが写真を枕元に飾らないと眠れないと言っていた"],
    "tojo": ["東条", "東条英機(1884–1948)。天辰の主人が「東条の細君、あれも女子大だといいますぜ」と言及する"],
    "rimbaud": ["ランボオ", "アルチュール・ランボー(1854–1891)。フランスの詩人。「私」が静子に詩集を持って行く"],
    "nietzsche": ["ニイチェ", "フリードリヒ・ニーチェ(1844–1900)。「私」が静子に『ツアラトウストラ』を持って行く"],
    "takahashi-oden": ["高橋お伝", "高橋お伝(1850頃–1879)。明治の毒婦として語られた実在の女性。友人が「高橋お伝ならまだしも」と忠告する"],
    "ganjiro": ["雁次郎", "初代中村鴈治郎(1860–1935)。成駒屋の歌舞伎役者。雁次郎横丁の名の由来として言及される"]
  },
