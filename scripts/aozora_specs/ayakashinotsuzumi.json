  "title": "あやかしの鼓",
  "author": "夢野久作",
  "fixes": {},
  "persons": {
    "kyuya": [
      "音丸久弥",
      "本作の語り手。音丸久能の曾孫で久意の次男。高林弥九郎の後嗣となり「高林久弥」を名乗る。あやかしの鼓に魅入られ、鶴原未亡人の変死・老先生の死の犯人と目されて、この遺書を残す。表層形「音丸久弥」「高林久弥」「久弥」「音丸君」「高林君」「音丸さん」を @ref で統合"
    ],
    "kuno": [
      "音丸久能",
      "百年前の京都の鼓作りの名人。今大路家の綾姫に恋い焦がれ、その輿入れに自作の鼓(後の「あやかしの鼓」)を贈った。鼓を取り返そうとして斬られ、鼓を打ち潰すよう遺言して死ぬ。表層形「音丸久能」「久能」"
    ],
    "kyuhaku": [
      "久伯",
      "音丸久能の子。父の跡を継いで鼓いじりを商売にした"
    ],
    "kyui": [
      "久意",
      "久伯の子、久能の孫。語り手久弥の父。京都から東京牛込へ移り、大正五年秋に肺炎で死ぬ直前に「あやかしの鼓」の由来を久弥に語る"
    ],
    "yasujiro": [
      "高林靖二郎",
      "高林弥九郎の養子で「若先生」。七年前に鼓を打って呪われ、鶴原家に「妻木敏郎」と名乗って甥として住み込む。その正体は久弥の実兄で、六つの年に他家へ遣られた久禄。表層形「高林靖二郎」「靖二郎」「靖」「妻木敏郎」「妻木君」「妻木」「敏郎」「久禄」を @ref で統合"
    ],
    "yakuro": [
      "高林弥九郎",
      "九段に住む能小鼓の名人。「老先生」。久意一家を東京に呼び寄せ、久弥を引き取って後嗣とした。最後にあやかしの鼓の呪いを解いた上で自ら縊死する"
    ],
    "ayahime": [
      "綾姫",
      "堂上方・今大路家の姫君。小鼓に堪能な美人。久能の思いを受けながら鶴原卿へ嫁ぎ、贈られた鼓を打った後に自害した。鶴原未亡人ツル子はその血筋を引く"
    ],
    "tsuruhara-kyo": [
      "鶴原卿",
      "百年前の堂上方。小鼓の上手で綾姫を娶り、あやかしの鼓を家に迎えた。関東への使者の帰途、浜松で吐血して落命する"
    ],
    "tsuruhara-shishaku": [
      "鶴原子爵",
      "大正期の鶴原家当主。維新後に子爵を授けられた家柄で、大阪で見初めた女(ツル子)を強引に妻とし親類から義絶された。妻があやかしの鼓を打った後に発狂し、座敷牢で衰弱死する。表層形「鶴原子爵」「鶴原の子爵様」"
    ],
    "tsuruko": [
      "ツル子",
      "鶴原子爵の未亡人。今大路家の綾姫の血筋を引く。淫蕩・残忍な美貌の女で、鞭で夫と妻木(靖二郎)を責め、久弥をも手に入れようとして刺殺される。作中の年齢三十一。表層形「鶴原子爵未亡人」「鶴原未亡人」「鶴原の未亡人」「鶴原の後家さん」「鶴原夫人」「ツル子」を @ref で統合"
    ],
    "sakon": [
      "左近",
      "鶴原家に召し抱えられた若侍。鼓を取り返しに忍び入った久能の肩先を斬った"
    ],
    "michiyo": [
      "美千代",
      "京都・祇園の舞妓。鶴原未亡人に似た眼鼻立ちで、久弥が声をかけ「鶴羽」で相手をした"
    ],
    "tamayo": [
      "玉代",
      "京都・祇園の舞妓。美千代と連れ立って歩いていた"
    ]
  },
