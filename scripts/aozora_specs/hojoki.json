  "persons": {
    "renin": [
      "蓮胤",
      "鴨長明(1155頃-1216)の法名。本作の作者にして語り手。本文末尾の「桑門蓮胤、外山の庵にしてこれをしるす」に自署として現れる"
    ],
    "saga-tenno": [
      "嵯峨天皇",
      "平安初期の天皇(786-842)。本文表記は「嵯峨の天皇」。平安京が都と定まった時代の天皇として言及される"
    ],
    "sutoku-in": [
      "崇徳院",
      "崇徳天皇(1119-1164)。長承の飢饉を「崇徳院の御位のとき」の先例として引く"
    ],
    "ryugyo": [
      "隆曉法印",
      "仁和寺慈尊院の大蔵卿。養和の飢饉の死者の額に阿字を書いて結縁させ、四万二千三百余の死骸を数えた僧"
    ],
    "manzei": [
      "滿沙彌",
      "沙弥満誓(笠麻呂)。『万葉集』の歌人。「世の中を何にたとへむ朝ぼらけ漕ぎゆく舟の跡の白波」の作者として、その「風情をぬすみ」と言及される"
    ],
    "minamoto-no-tsunenobu": [
      "源経信",
      "平安後期の歌人・音楽家(1016-1097)。大宰帥(唐名「都督」)。本文表記は「源都督」と割注の「經信」。琵琶の「流泉」の曲を伝えた人として言及される"
    ],
    "semimaru": [
      "蝉丸",
      "逢坂の関に住んだと伝える伝説的歌人・琵琶の名手。本文表記は「蝉丸翁」。粟津の原にその迹をとぶらう"
    ],
    "sarumaru-dayu": [
      "猿丸大夫",
      "伝説的歌人。田上川のほとりにその墓をたずねる"
    ],
    "jomyo-koji": [
      "淨名居士",
      "維摩詰(ゆいまきつ)。方丈の室に住したという在家の仏教者。方丈の庵の典拠として引かれる"
    ],
    "shurihandoku": [
      "周梨槃特",
      "釈迦の弟子。愚鈍でありながら悟りを得たとされる。長明が自らの修行の及ばなさを比する相手"
    ],
    "amida": [
      "阿彌陀",
      "阿弥陀如来。方丈の庵の西の垣に画像を安置する本尊"
    ],
    "fugen": [
      "普賢",
      "普賢菩薩。庵の帳の扉に不動とならべて像を掛ける"
    ],
    "fudo": [
      "不動",
      "不動明王。庵の帳の扉に普賢とならべて像を掛ける"
    ]
  },
