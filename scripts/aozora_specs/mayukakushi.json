  "author": "泉鏡花",
  "fixes": {},
  "persons": {
    "sakai": [
      "境賛吉",
      "語り手(筆者)の友。木曾街道を旅し、奈良井宿の旅籠に逗留して怪異に遭う。本文では姓の「境」で呼ばれる"
    ],
    "isaku": [
      "伊作",
      "旅籠の料理番。伊那の出。池の魚を愛惜する。お艶の最期に立ち会った当事者で、物語の後半を語る"
    ],
    "oyone": [
      "お米",
      "旅籠の若い女中。臆病者で「米ちゃん」とも呼ばれる。名は木曾節の「余り米」にちなんで話題にされる"
    ],
    "otsuya": [
      "お艶",
      "柳橋の芸妓「蓑吉」。宿帳の名はお艶。画師の情婦。眉を落とし鉄漿をつけた姿で代官婆に会いに行き、猟師石松に撃たれて死ぬ。作品表題の「眉かくしの霊」となる"
    ],
    "daikanbaba": [
      "代官婆",
      "雁股の庄屋の後家。「代官婆」は本文が明示する渾名で、作中この呼称以外の名を持たない。訴訟狂で、嫁と画師の姦通を摘発する"
    ],
    "ishimatsu": [
      "石松",
      "棒鼻の辻に住む猟師。代官婆の旧奉公人。桔梗ヶ池の奥様と見誤ってお艶を撃つ"
    ],
    "yajirobe": [
      "弥次郎兵衛",
      "『東海道中膝栗毛』の主人公。「弥次郎」とも。作中では奈良井の蕎麦二膳の挿話として想起される"
    ],
    "kitahachi": [
      "喜多八",
      "『東海道中膝栗毛』の弥次郎兵衛の道連れ"
    ],
    "kanbee": [
      "鐶兵衛",
      "膝栗毛の趣向で語られる、江戸お箪笥町引出し横町の取手屋の主。弥次郎・喜多八の馴染"
    ],
    "iwami": [
      "岩見重太郎",
      "豪傑として知られる伝説上の武人。境が銚子を一度に頼む自分を戯れになぞらえる"
    ],
    "katsuyori": [
      "勝頼",
      "武田勝頼。伊那出身の伊作を評して「勝頼様と同国ですな」と言及される"
    ],
    "yuranosuke": [
      "大星由良之助",
      "『仮名手本忠臣蔵』の大星由良之助。二つ巴の紋から連想され、本文では「大星」「由良之助」と分けて言及される"
    ],
    "kisodono": [
      "木曾殿",
      "木曾義仲。二つ巴の紋から巴御前の故事(木曾殿の寵愛)が連想される"
    ],
    "sanshakubo": [
      "秋葉山三尺坊",
      "秋葉山の三尺坊。火防の天狗・神。饂飩二膳の冷遇を「三尺坊が飯綱権現へ客を断ちものにした」と戯れに言う"
    ],
    "izunagongen": [
      "飯綱権現",
